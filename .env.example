# Copy this file to .env and fill in real values. Never commit .env.
# This file (.env.example) IS committed — keep it placeholders only.

# Application
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_STORAGE_SECRET=change-me-to-a-random-string

# Database — normally omit this so the app derives <RFP_DATA_DIR>/sqlite.db
# (or ./data/sqlite.db when RFP_DATA_DIR is unset). If you set both variables,
# DATABASE_URL must point to sqlite.db inside that same workspace.
# DATABASE_URL=sqlite:///./data/sqlite.db

# Redis (used by RQ for background jobs)
REDIS_URL=redis://redis:6379/0

# LLM providers — leave blank in foundation phase; required for Phase 1 agent work
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# Cost guardrails (USD)
PER_RUN_COST_CAP=200
MONTHLY_COST_CAP=2000

# Auto review-revise loop concurrency. Each worker drives ONE section's
# full pass cycle (Reviewer A → Reviewer B → Writer regenerate, repeat)
# against its own LLM sessions, so 4 workers ≈ 4-5x faster than serial
# on a typical 18-section RFP. The 429 retry/backoff in services/llm.py
# absorbs occasional rate-limit spikes. Set to 1 to fall back to serial.
AUTO_LOOP_WORKERS=4

# Shortfall Strategist batch concurrency during intake. Batches share
# the cached prefix (profile + KB + teaming + decisions, ~58K tokens) —
# the first to land writes the cache, the rest read it. 4 workers cuts
# shortfall wall-time ~3x on a typical 6-batch RFP at the same total
# cost. Set to 1 for serial behavior.
SHORTFALL_WORKERS=4

# Default model assignments (override per-agent in app/config.py if desired).
#
# Three-provider stack by default for review-time provider diversity:
#   Writer Team   = Anthropic (Opus)        — customer-visible prose
#   Reviewer A    = OpenAI (GPT-5.5)        — adversarial honesty/compliance
#   Reviewer B    = Google  (Gemini 2.5)    — persuasion / evaluator psych
# Different training distributions = different blind spots. The dispatcher
# in app/services/llm.py routes by model name prefix (claude-* / gpt-* /
# o*-* / gemini-*), so you can swap any model name and it'll route correctly.

# Drafting agents that aren't the Writer (Compliance Matrix, Outline Agent,
# Shortfall Strategist). Sonnet is the right cost/quality point.
MODEL_DRAFTER=claude-sonnet-4-6

# Writer Team REVISION model — used by per-section regenerate (auto loop
# applying findings, manual Regenerate, Refine-with-AI). Opus because
# revisions target reviewer-flagged issues where reasoning matters most.
MODEL_WRITER_TEAM=claude-opus-4-7
# Writer Team INITIAL DRAFT model — used by the multi-section first draft.
# Sonnet because first-draft quality is 80-90% of Opus and the auto loop
# polishes weak sections via Opus revisions anyway. Saves ~5x on the most
# expensive single batch (18 sections × cache write × full output).
MODEL_WRITER_TEAM_INITIAL=claude-sonnet-4-6

# Reviewer A — adversarial honesty/compliance. GPT-5.5 by default for
# provider diversity vs the Anthropic writer. Override to claude-opus-4-7
# if you want Anthropic-on-Anthropic.
MODEL_REVIEWER_A=gpt-5.5

# Reviewer B — persuasion. Gemini 2.5 Flash by default.
MODEL_REVIEWER_B=gemini-2.5-flash

MODEL_LIGHT_EXTRACTION=claude-haiku-4-5-20251001

# Requirements pipeline. Source extraction stays on Sonnet. Independent
# classification + source-completeness review stays cross-provider on Gemini;
# Haiku is a last-resort leaf fallback after smaller-batch retries and is
# surfaced as degraded whenever used.
MODEL_COMPLIANCE_MATRIX=claude-sonnet-4-6
MODEL_COMPLIANCE_VALIDATOR=gemini-2.5-pro
MODEL_COMPLIANCE_VALIDATOR_FALLBACK=claude-haiku-4-5-20251001

# Cost Reviewer (Weeks 12-13) — Pro tier; cost mistakes are unrecoverable.
MODEL_COST_REVIEWER=gemini-3.5-pro
# Teaming Researcher — runs after Shortfall Strategist on every teaming
# gap to enrich partner_suggestions with Gemini's broader market recall.
# Pro tier matters: Flash hallucinates firm names too often for this.
MODEL_TEAMING_RESEARCHER=gemini-2.5-pro
EMBEDDING_MODEL=voyage-3-large

# Sentry (optional)
SENTRY_DSN=
